# wrangler.toml.example — swear-jar leaderboard funnel Worker.
#
# PLACEHOLDERS ONLY. Copy to funnel/wrangler.toml (kept OUT of the repo),
# fill in real values from the owner's Cloudflare account, then
# `wrangler deploy` from this directory. Deployment is an owner act;
# nothing goes live until the owner's pre-launch review.

name = "swear-jar-funnel"
main = "worker.mjs"
compatibility_date = "2026-07-01"

# ── KV: the one namespace (pending rows, confirmed rows, rate counters) ──────
# Create it with:  wrangler kv namespace create JAR
# then paste the id it prints below.
[[kv_namespaces]]
binding = "JAR"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

# ── plain vars (not secret, but still environment-specific) ──────────────────
[vars]
# From address for the confirmation email (domain must be verified in Resend).
MAIL_FROM = "jar@unfocused.ai"
# Host used in the confirm link + default thanks redirect (the Worker's host).
PUBLIC_HOST = "jar.unfocused.ai"
# The ONE origin allowed to POST /api/submit (where docs/submit.html is served).
ALLOWED_ORIGIN = "https://unfocused.ai"
# Optional: override the post-confirmation redirect.
THANKS_URL = "https://unfocused.ai/thanks"
# Optional: comma-separated release hashes that earn the `verified` badge.
KNOWN_RELEASES = "cd15e0b"

# ── secrets — NEVER in this file, NEVER in the repo ──────────────────────────
# Set with wrangler after the first deploy target exists:
#   wrangler secret put RESEND_API_KEY   # owner's Resend API key
#   wrangler secret put ADMIN_TOKEN      # long random string, gates /api/export.csv
#                                        #   e.g. openssl rand -hex 32
